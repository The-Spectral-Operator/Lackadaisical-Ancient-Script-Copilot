{
  "compilerOptions": {
    "checkJs": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2023",
    "lib": ["ES2023"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["server/src/**/*.js", "webui/js/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
