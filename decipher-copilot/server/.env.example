# Ancient Script Decipherment Copilot — Environment Configuration
# Copy to .env and adjust values as needed

# Ollama connection
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_API_KEY=

# Server
DECIPHER_HOST=127.0.0.1
DECIPHER_PORT=7340

# Models
DECIPHER_MODEL=gemma4:e4b
DECIPHER_VISION_MODEL=aurora-elwing-v2:latest
DECIPHER_EMBED_MODEL=nomic-embed-text

# Data paths (defaults to decipher-copilot/data and decipher-copilot/datasets)
# DECIPHER_DATA_DIR=
# DECIPHER_DATASETS_DIR=

# Security
# DECIPHER_DB_PASSPHRASE=your-secure-passphrase-here

# Logging
DECIPHER_LOG_LEVEL=info
